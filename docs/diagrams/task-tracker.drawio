        <mxCell id="3012" parent="3001" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=middle;spacing=8;fillColor=#ffffff;strokeColor=#666666;" value="4. Developer moves task to selected" vertex="1">
          <mxGeometry height="60" width="320" x="-360" y="350" as="geometry" />
        </mxCell>
        <mxCell id="3013" parent="3001" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=middle;spacing=8;fillColor=#ffffff;strokeColor=#666666;" value="5. Developer moves to in_progress&#xa;in_progress_started_at = now" vertex="1">
