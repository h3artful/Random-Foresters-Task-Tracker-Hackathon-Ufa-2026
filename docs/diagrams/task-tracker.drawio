        </mxCell>
        <mxCell id="3011" parent="3001" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=middle;spacing=8;fillColor=#ffffff;strokeColor=#666666;" value="3. Task + audit log saved" vertex="1">
