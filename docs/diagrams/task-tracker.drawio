        </mxCell>
        <mxCell id="3010" parent="3001" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=middle;spacing=8;fillColor=#ffffff;strokeColor=#666666;" value="2. Router checks role, project context, assignee, sprint and duplicates" vertex="1">
