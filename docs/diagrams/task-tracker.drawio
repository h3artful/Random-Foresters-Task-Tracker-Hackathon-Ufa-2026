        </mxCell>
        <mxCell id="3009" parent="3001" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=middle;spacing=8;fillColor=#ffffff;strokeColor=#666666;" value="1. Manager creates task&#xa;POST /projects/{project_id}/tasks" vertex="1">
